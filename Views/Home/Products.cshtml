@{
    ViewData["Title"] = "المنتجات";
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold text-primary"> المنتجات المتوفرة</h1>
        <p class="text-muted">اختر المنتج المناسب لك</p>
    </div>

    @if (ViewBag.Filtered.Count == 0)
    {
        <div class="alert alert-warning text-center fs-4">
            لا توجد منتجات متاحة حالياً
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (dynamic item in ViewBag.Filtered)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow border-0 h-100 product-card">

                        <img src="~/images/@item.Image"
                             class="card-img-top"
                             style="height:300px; object-fit:cover;">

                        <div class="card-body text-center">

                            <h4 class="fw-bold mb-3">
                                @item.Name
                            </h4>

                            <h5 class="text-danger fw-bold mb-3">
                                @item.Price ريال
                            </h5>

                            <a asp-action="Details"
                               asp-route-name="@item.Name"
                               class="btn btn-primary w-100">
                                عرض التفاصيل
                            </a>

                        </div>
                    </div>
                </div>
            }
        </div>
    }

</div>

<style>
    .product-card {
        transition: all .3s ease;
        border-radius: 15px;
        overflow: hidden;
    }

    .product-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 10px 25px rgba(0,0,0,.2) !important;
    }

    .card-img-top {
        border-bottom: 1px solid #eee;
    }

    .btn-primary {
        border-radius: 10px;
    }
</style>