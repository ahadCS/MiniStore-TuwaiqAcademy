@{
    ViewData["Title"] = "الرئيسية";
}
<div class="container py-4">
   <!-- Title -->
    <div class="text-center mb-5">
        <h2 class="fw-bold section-title">
            الأقسام الرئيسية
        </h2>
        <p class="text-muted">
            اختر القسم الذي ترغب بتصفحه
        </p>
    </div>

    <!-- Categories -->
    <div class="row g-4">

        @foreach (var item in ViewBag.CatergoriesList)
        {
            <div class="col-lg-4 col-md-6">

                <div class="card category-card h-100 border-0">

                    <div class="card-body text-center p-5">

                        <div class="icon-box mb-4">
                            <i class="@item.Icon"></i>
                        </div>

                        <h3 class="fw-bold mb-4">
                            @item.Name
                        </h3>

                        <a asp-action="Products"
                           asp-route-id="@item.Id"
                           class="btn btn-primary px-4">
                            عرض المنتجات
                        </a>

                    </div>

                </div>

            </div>
        }

    </div>

</div>

<style>

    body{
        background:#f8fafc;
    }

    .hero-section{
        background:linear-gradient(135deg,#60a1b1,#06b6d4);
        padding:70px 20px;
        border-radius:25px;
        box-shadow:0 10px 30px rgba(0,0,0,.15);
    }

    .section-title{
        color:#1e293b;
    }

    .category-card{
        border-radius:20px;
        transition:.4s;
        background:white;
        box-shadow:0 5px 20px rgba(0,0,0,.08);
    }

    .category-card:hover{
        transform:translateY(-10px);
        box-shadow:0 15px 35px rgba(0,0,0,.15);
    }

    .icon-box{
        font-size:65px;
        color:#5186c2;
    }

    .btn-primary{
        background:#5186c2;
        border:none;
        border-radius:12px;
        padding:10px 25px;
    }

    .btn-primary:hover{
        background:#3730a3;
    }

</style>